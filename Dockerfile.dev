# Imagem de desenvolvimento: deps completas + watch mode.
# Uso: docker-compose up (com dockerfile: Dockerfile.dev no compose).
FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=development

# Instala dependências (incluindo devDependencies para build/watch)
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

# Código é montado via volume no docker-compose
COPY . .

EXPOSE 3000

CMD ["yarn", "start:dev"]
